graph TB
    subgraph "Markdown Source of Truth"
        MEM["MEMORY.md<br/><i>global agent notes</i>"]
        USR["USER.md<br/><i>user profile</i>"]
        FAIL["failures.md<br/><i>categorized lessons</i>"]
        PMEM["projects-memory/&lt;project&gt;/MEMORY.md<br/><i>project-scoped notes</i>"]
    end

    subgraph "SQLite Search Store"
        SQM["memories + memory_fts<br/><i>search mirror/backfill</i>"]
        SQS["sessions/messages + message_fts<br/><i>conversation search</i>"]
    end

    subgraph "System Prompt"
        POLICY["memory-policy<br/><i>policy-only by default</i>"]
        STYLE["memoryPolicyStyle<br/><i>full / compact / custom / none</i>"]
    end

    subgraph "Skills"
        GSKL["pi-hermes-memory/skills/<br/><i>global skills</i>"]
        PSKL["projects-memory/&lt;project&gt;/skills/<br/><i>project skills via resources_discover</i>"]
        SKILLTOOL["skill tool<br/><i>create / view / patch / update / delete</i>"]
    end

    subgraph "On Demand Retrieval"
        MSEARCH["memory_search<br/><i>query durable memories</i>"]
        SSEARCH["session_search<br/><i>query indexed sessions</i>"]
        BACKFILL["/memory-sync-markdown<br/><i>idempotent Markdown → SQLite</i>"]
    end

    STYLE --> POLICY
    POLICY --> MSEARCH
    POLICY --> SSEARCH
    POLICY --> SKILLTOOL

    MEM -. successful writes .-> SQM
    USR -. successful writes .-> SQM
    FAIL -. successful writes .-> SQM
    PMEM -. successful writes .-> SQM
    BACKFILL --> SQM
    MSEARCH --> SQM
    SSEARCH --> SQS

    SKILLTOOL --> GSKL
    SKILLTOOL --> PSKL

    style POLICY fill:#1a1a2e,stroke:#e94560,color:#fff
    style STYLE fill:#16213e,stroke:#0f3460,color:#fff
    style SQM fill:#0b525b,stroke:#fff,color:#fff
    style SQS fill:#1b4332,stroke:#fff,color:#fff
    style SKILLTOOL fill:#16213e,stroke:#0f3460,color:#fff
